# Default: always use LF
* text=auto eol=lf

# Explicit text formats
*.java      text eol=lf
*.kt        text eol=lf
*.gradle    text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.service   text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.mp4       binary
*.zip       binary
*.jar       binary
*.keystore  binary
