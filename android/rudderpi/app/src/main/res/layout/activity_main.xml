<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/black">

    <TextView
        android:id="@+id/tvHTTPServerHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="HTTP Server Settings"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/inpHTTPServerXAuthHeaderPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="HTTP Server X-Auth Header Password"
        android:layout_marginTop="12dp"
        android:inputType="text"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvHTTPServerHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRtspSettingsHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="RTSP Client Settings"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/inpHTTPServerXAuthHeaderPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/inpRtspRemoteServerIP4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="RTSP Remote Upstream Server IPv4 / Hostname"
        android:layout_marginTop="12dp"
        android:inputType="textUri"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tvRtspSettingsHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/inpRtspRemoteServerPort"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="RTSP Remote Upstream Server Port"
        android:layout_marginTop="12dp"
        android:inputType="number"
        android:digits="0123456789"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/inpRtspRemoteServerIP4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnApplySettings"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Apply all settings"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/inpRtspRemoteServerPort"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnAdmin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Admin: Tethering / Network settings"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnApplySettings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvAppStatusHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="APP Status (Newest at top)"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnAdmin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:scrollbars="vertical"
        android:padding="8dp"
        android:textIsSelectable="true"
        android:textSize="11sp"
        android:textColor="@android:color/white"
        android:typeface="monospace"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppStatusHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hidden, only used by the service/library -->
    <com.pedro.rtplibrary.view.OpenGlView
        android:id="@+id/glView"
        android:layout_width="2dp"
        android:layout_height="2dp"
        android:alpha="0.0"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

